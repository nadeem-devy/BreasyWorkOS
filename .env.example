# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook Secrets
BUBBLE_WEBHOOK_SECRET=your-bubble-webhook-secret
DIALPAD_WEBHOOK_SECRET=your-dialpad-webhook-secret

# Dialpad API
DIALPAD_API_KEY=your-dialpad-api-key

# Gmail API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Melio API
MELIO_API_KEY=your-melio-api-key

# Bubble Data API
BUBBLE_API_KEY=your-bubble-api-key
BUBBLE_APP_NAME=your-bubble-app-name

# Vercel Cron Secret
CRON_SECRET=your-cron-secret
